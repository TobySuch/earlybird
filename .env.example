# ── App ───────────────────────────────────────────────────────────────────────
# A random secret used for session signing. Generate with: openssl rand -hex 32
SECRET_KEY=changeme

# SQLite database path. Use an absolute path when running in Docker.
DATABASE_URL=sqlite:///./data/earlybird.db

# ── LLM ───────────────────────────────────────────────────────────────────────
# Claude Haiku — used for filtering and summarisation in pipeline/process.py
ANTHROPIC_API_KEY=

# ElevenLabs — used for TTS audio generation in pipeline/publish.py
# Enable TTS and configure voice/model in the Settings UI once this is set.
ELEVENLABS_API_KEY=

# OpenAI — used when the LLM provider is set to "OpenAI / compatible" in the Settings UI.
# Also works with any OpenAI-compatible endpoint (Ollama, LM Studio, vLLM, etc.) —
# set the base URL in the Settings UI after enabling this provider.
OPENAI_API_KEY=

# Optional: separate API key for TTS when using the OpenAI TTS provider.
# Useful if you use a different service for digest (e.g. OpenRouter) and OpenAI for TTS.
# Falls back to OPENAI_API_KEY if not set.
OPENAI_TTS_API_KEY=

# ── Gmail OAuth2 ──────────────────────────────────────────────────────────────
# Create a project at https://console.cloud.google.com/, enable the Gmail API,
# and create OAuth2 credentials (Desktop app type).
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# ── MLflow Tracing (optional) ─────────────────────────────────────────────────
# Set MLFLOW_TRACKING_URI to enable automatic LLM call tracing.
# MLFLOW_EXPERIMENT_NAME defaults to "Default" if not set.
MLFLOW_TRACKING_URI=
MLFLOW_EXPERIMENT_NAME=
