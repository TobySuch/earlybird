# ── App ───────────────────────────────────────────────────────────────────────
# A random secret used for session signing. Generate with: openssl rand -hex 32
SECRET_KEY=changeme

# SQLite database path. Use an absolute path when running in Docker.
DATABASE_URL=sqlite:///./data/earlybird.db

# ── LLM ───────────────────────────────────────────────────────────────────────
# Claude Haiku — used for filtering and summarisation in pipeline/process.py
ANTHROPIC_API_KEY=

# OpenAI — used for TTS (tts-1-hd) in pipeline/publish.py
OPENAI_API_KEY=

# ── Gmail OAuth2 ──────────────────────────────────────────────────────────────
# Create a project at https://console.cloud.google.com/, enable the Gmail API,
# and create OAuth2 credentials (Desktop app type).
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# ── Audiobookshelf ────────────────────────────────────────────────────────────
# Base URL of your ABS instance (no trailing slash)
ABS_URL=https://abs.example.com
# API key from ABS → Settings → Users → your user → API token
ABS_API_KEY=
